#!/bin/bash
LOG_DIR="/var/log/myapp"          # Directory containing the logs (adjust as needed)
ARCHIVE_DIR="/var/log/myapp/archive" # Directory to store archived logs (adjust as needed)
RETENTION_DAYS=7                  # Files older than this will be archived/removed

# Create archive directory if it doesn't exist
mkdir -p "$ARCHIVE_DIR"

# Find logs older than RETENTION_DAYS days
find "$LOG_DIR" -maxdepth 1 -name "*.log" -type f -mtime +"$RETENTION_DAYS" | while read FILE; do
  if [[ -f "$FILE" ]]; then
    # Get filename without extension
    BASENAME=$(basename "$FILE" .log)
    # Define archive name with date
    ARCHIVE_NAME="${BASENAME}-$(date +%Y%m%d).tar.gz"

    echo "Archiving and compressing $FILE to $ARCHIVE_DIR/$ARCHIVE_NAME"
    
    # Compress the file using tar and gzip, and move to the archive directory
    tar -czf "$ARCHIVE_DIR/$ARCHIVE_NAME" -C "$(dirname "$FILE")" "$(basename "$FILE")"
    
    # Check if archiving was successful before removing the original file
    if [ $? -eq 0 ]; then
      echo "Removing original file: $FILE"
      rm "$FILE"
    else
      echo "Error archiving $FILE. Original file not removed."
    fi
  fi
done



